# .env.example — safe template for project environment variables
# Copy this to .env.local or .env.dev and fill real secrets.
# DO NOT commit any real secrets or production credentials.

# App environment
APP_ENV=dev
APP_SECRET=replace_with_a_random_secret
APP_SHARE_DIR=var/share

# Routing
DEFAULT_URI=http://localhost

# Doctrine / Database
# Replace `your_db_password` and other values as needed.
DATABASE_URL="postgresql://app:your_db_password@127.0.0.1:5432/app?serverVersion=16&charset=utf8"

# Messenger transport (choose and configure for your environment)
# Examples:
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Mailer
MAILER_DSN=null://null

# Notes:
# - Keep sensitive values (API keys, DB passwords) out of committed files.
# - For local overrides use .env.local or .env.<env>.local which should be gitignored.
# - For CI, provide env vars via your CI provider or a secured secrets store.
