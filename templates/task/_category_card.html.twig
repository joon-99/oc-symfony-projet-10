<div class="task-column">
    <h2>{{ category.name }}</h2>
    <div class="tasks-list">

        {% for task in tasks %}
            {% if is_granted('TASK_VIEW', task) %}
                {% include 'task/_task_card.html.twig' with {'task': task} %}
            {% endif %}
        {% endfor %}

        {% if is_granted('PROJECT_ADD_TASK', project) %}
            <a href="{{ path('app_task_new', {'project': project.id}) }}" data-turbo="false" class="task-add">
            + Ajouter une tâche
            </a>
        {% endif %}
    </div>
</div>